<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>Unlock Likes</title>
<script src="https://telegram.org/js/telegram-web-app.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;background:var(--tg-bg-color,#1a1a2e);color:var(--tg-text-color,#e0e0e0);display:flex;flex-direction:column;align-items:center;min-height:100vh;padding:20px 16px;padding-bottom:calc(20px + env(safe-area-inset-bottom,0px))}
.hidden{display:none!important}
.card{background:var(--tg-secondary-bg-color,#252540);border-radius:14px;padding:24px 20px;width:100%;max-width:400px;box-shadow:0 2px 12px rgba(0,0,0,.3);margin-top:10px}
.header{display:flex;align-items:center;gap:10px;margin-bottom:4px}
.header svg{width:28px;height:28px}
.header h1{font-size:18px;font-weight:700;color:var(--tg-text-color,#fff)}
.subtitle{font-size:13px;color:var(--tg-hint-color,#999);margin-bottom:20px}
.info-row{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.06)}
.info-row:last-child{border-bottom:none}
.info-label{font-size:14px;color:var(--tg-hint-color,#999)}
.info-value{font-size:14px;font-weight:600;color:var(--tg-text-color,#fff)}
.btn{width:100%;padding:14px;border:none;border-radius:12px;font-size:16px;font-weight:600;cursor:pointer;transition:opacity .2s,transform .1s;display:flex;align-items:center;justify-content:center;gap:8px}
.btn:active{transform:scale(.97)}
.btn-primary{background:var(--tg-button-color,#5b9aff);color:var(--tg-button-text-color,#fff);margin-top:20px}
.btn-primary:hover{opacity:.9}
.btn-primary:disabled{opacity:.5;cursor:not-allowed}
.btn-success{background:var(--tg-button-color,#5b9aff);color:var(--tg-button-text-color,#fff);margin-top:16px}
.progress-wrap{background:rgba(255,255,255,.08);border-radius:10px;height:8px;width:100%;margin-top:16px;overflow:hidden}
.progress-fill{height:100%;width:0%;background:var(--tg-button-color,#5b9aff);border-radius:10px;transition:width .3s}
.status-text{text-align:center;font-size:13px;color:var(--tg-hint-color,#999);margin-top:8px}
.success-icon{width:60px;height:60px;border-radius:50%;background:var(--tg-button-color,#5b9aff);display:flex;align-items:center;justify-content:center;margin:10px auto 16px}
.success-icon svg{width:32px;height:32px;fill:#fff}
.success-title{font-size:20px;font-weight:700;text-align:center;color:var(--tg-text-color,#fff);margin-bottom:4px}
.success-sub{font-size:13px;text-align:center;color:var(--tg-hint-color,#999)}
.footer{text-align:center;font-size:11px;color:var(--tg-hint-color,#666);margin-top:16px}
.spinner{width:32px;height:32px;border:3px solid rgba(255,255,255,.1);border-top-color:var(--tg-button-color,#5b9aff);border-radius:50%;animation:spin .8s linear infinite;margin:20px auto}
@keyframes spin{to{transform:rotate(360deg)}}
.fade-in{animation:fadeIn .4s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.badge{align-self:flex-start;background:var(--tg-button-color,#5b9aff);color:var(--tg-button-text-color,#fff);font-size:12px;font-weight:600;padding:4px 12px;border-radius:20px;margin-bottom:12px}
</style>
</head>
<body>
<div class="badge">Free Fire Likes Generator</div>

<div id="screen-idle" class="card fade-in">
  <div class="header">
    <svg viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" fill="var(--tg-button-color,#5b9aff)"/></svg>
    <h1>Unlock Likes</h1>
  </div>
  <p class="subtitle">Watch a short ad to generate Free Fire likes for your account.</p>
  <div class="info-row"><span class="info-label">Player UID</span><span class="info-value" id="display-uid">—</span></div>
  <div class="info-row"><span class="info-label">Likes Requested</span><span class="info-value" id="display-likes">—</span></div>
  <div class="info-row"><span class="info-label">Ad Type</span><span class="info-value">Rewarded Video</span></div>
  <button id="btn-watch" class="btn btn-primary" onclick="startAd()">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
    Watch Ad to Unlock
  </button>
</div>

<div id="screen-playing" class="card hidden fade-in">
  <div class="spinner"></div>
  <p class="status-text" id="playing-status">Loading ad...</p>
  <div class="progress-wrap"><div class="progress-fill" id="progress-fill"></div></div>
  <p class="status-text" id="progress-text">Please wait...</p>
</div>

<div id="screen-completed" class="card hidden fade-in">
  <div class="success-icon"><svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg></div>
  <div class="success-title">Likes Unlocked!</div>
  <p class="success-sub">Your likes have been generated. Check Telegram.</p>
  <button class="btn btn-success" onclick="Telegram.WebApp.close()">Close</button>
</div>

<p class="footer">Powered by Monetag</p>

<script>
(function() {
  const urlParams = new URLSearchParams(window.location.search);
  const uid = urlParams.get('uid') || 'Unknown';
  const likes = urlParams.get('likes') || '100';
  const zoneId = urlParams.get('zone') || '';

  document.getElementById('display-uid').textContent = uid;
  document.getElementById('display-likes').textContent = likes;

  window._adCompleted = false;

  if (zoneId) {
    var s = document.createElement('script');
    s.src = '//libtl.com/sdk.js';
    s.setAttribute('data-zone', zoneId);
    s.setAttribute('data-sdk', 'show_' + zoneId);
    s.onerror = function() { console.warn('Monetag SDK failed, using fallback'); };
    document.head.appendChild(s);
  }
})();

function setScreen(id) {
  ['screen-idle','screen-playing','screen-completed'].forEach(function(s) {
    document.getElementById(s).classList.toggle('hidden', s !== id);
  });
}

function startAd() {
  document.getElementById('btn-watch').disabled = true;
  setScreen('screen-playing');
  animateProgress();

  var zoneId = new URLSearchParams(window.location.search).get('zone') || '';
  var uid = new URLSearchParams(window.location.search).get('uid') || 'Unknown';
  var likes = new URLSearchParams(window.location.search).get('likes') || '100';

  if (zoneId && typeof window['show_' + zoneId] === 'function') {
    document.getElementById('playing-status').textContent = 'Loading ad...';
    window['show_' + zoneId]().then(function() {
      onAdComplete(uid, likes);
    }).catch(function() {
      fallbackAd(uid, likes);
    });
  } else {
    document.getElementById('playing-status').textContent = 'Ad network unavailable. Using test mode...';
    setTimeout(function() {
      fallbackAd(uid, likes);
    }, 1500);
  }
}

function fallbackAd(uid, likes) {
  document.getElementById('playing-status').textContent = 'Watching ad (test mode)...';
  var start = Date.now();
  var duration = 8000;
  var interval = setInterval(function() {
    var elapsed = Date.now() - start;
    var pct = Math.min(100, (elapsed / duration) * 100);
    document.getElementById('progress-fill').style.width = pct + '%';
    document.getElementById('progress-text').textContent = Math.floor(pct) + '%';
    if (pct >= 100) {
      clearInterval(interval);
      onAdComplete(uid, likes);
    }
  }, 100);
}

function animateProgress() {
  var pct = 0;
  var interval = setInterval(function() {
    pct += Math.random() * 8;
    if (pct > 92) pct = 92;
    document.getElementById('progress-fill').style.width = pct + '%';
    document.getElementById('progress-text').textContent = Math.floor(pct) + '%';
  }, 400);
  window._progressInterval = interval;
}

function onAdComplete(uid, likes) {
  if (window._adCompleted) return;
  window._adCompleted = true;
  if (window._progressInterval) clearInterval(window._progressInterval);
  document.getElementById('progress-fill').style.width = '100%';
  document.getElementById('progress-text').textContent = '100%';
  document.getElementById('playing-status').textContent = 'Ad completed!';

  setTimeout(function() {
    Telegram.WebApp.sendData(JSON.stringify({
      status: 'completed',
      uid: uid,
      likes: parseInt(likes) || 100
    }));
    setScreen('screen-completed');
  }, 500);
}

Telegram.WebApp.ready();
Telegram.WebApp.expand();
</script>
</body>
</html>
